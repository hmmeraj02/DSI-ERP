<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="ir_cron_absent_deduction" model="ir.cron">
            <field name="name">DSL: Auto Absent Leave Deduction</field>
            <field name="model_id" ref="model_absent_deduction_config"/>
            <field name="state">code</field>
            <field name="code">model.run_absent_deduction()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <!-- প্রতিদিন রাত ১১:০০ তে চলবে (UTC — BD = UTC+6, তাই 17:00 UTC) -->
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).replace(hour=17, minute=0, second=0)"/>
            <field name="priority">10</field>
        </record>

    </data>
</odoo>
