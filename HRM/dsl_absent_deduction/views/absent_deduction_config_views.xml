<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Form View ─────────────────────────────────────────────────────── -->
    <record id="view_absent_deduction_config_form" model="ir.ui.view">
        <field name="name">absent.deduction.config.form</field>
        <field name="model">absent.deduction.config</field>
        <field name="arch" type="xml">
            <form string="Absent Leave Deduction Configuration">
                <header>
                    <button
                        name="action_run_now"
                        string="▶ Run Now"
                        type="object"
                        class="btn-primary"
                        confirm="Will you process the absent deduction for yesterday now?"
                    />
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button
                            name="action_view_logs"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-list-alt"
                        >
                            <field name="log_count" widget="statinfo" string="Logs"/>
                        </button>
                    </div>

                    <group>
                        <group string="Basic Settings">
                            <field name="company_id"/>
                            <field name="active"/>
                            <field name="time_off_type_id"
                                domain="[('company_id', 'in', [company_id, False])]"
                            />
                        </group>
                        <group string="Behaviour">
                            <!-- <field name="auto_create_allocation"/> -->
                            <field name="check_previous_days"/>
                        </group>
                    </group>

                    <!-- Warning if auto_create_allocation is off -->
                    <!-- <div class="alert alert-warning" role="alert"
                        invisible="auto_create_allocation == True">
                        <strong>Auto-Create Disabled:</strong>
                        Make sure all employees have validated allocations for the selected
                        time-off type. Otherwise, deductions will fail.
                    </div> -->

                    <group string="Last Run Info">
                        <field name="last_run" readonly="1"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ── List View ─────────────────────────────────────────────────────── -->
    <record id="view_absent_deduction_config_list" model="ir.ui.view">
        <field name="name">absent.deduction.config.list</field>
        <field name="model">absent.deduction.config</field>
        <field name="arch" type="xml">
            <tree string="Absent Deduction Config">
                <field name="company_id"/>
                <field name="time_off_type_id"/>
                <!-- <field name="auto_validate"/> -->
                <!-- <field name="auto_create_allocation"/> -->
                <field name="last_run"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- ── Action ────────────────────────────────────────────────────────── -->
    <record id="action_absent_deduction_config" model="ir.actions.act_window">
        <field name="name">Absent Deduction Config</field>
        <field name="res_model">absent.deduction.config</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
