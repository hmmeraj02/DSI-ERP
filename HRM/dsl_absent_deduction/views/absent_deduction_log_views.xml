<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List View ─────────────────────────────────────────────────────── -->
    <record id="view_absent_deduction_log_list" model="ir.ui.view">
        <field name="name">absent.deduction.log.list</field>
        <field name="model">absent.deduction.log</field>
        <field name="arch" type="xml">
            <tree string="Absent Deduction Logs" decoration-success="status == 'deducted'" decoration-muted="status == 'skipped'">
                <field name="check_date"/>
                <field name="employee_id"/>
                <field name="status"
                    widget="badge"
                    decoration-success="status == 'deducted'"
                    decoration-warning="status == 'skipped'"
                />
                <field name="reason"/>
                <field name="run_at"/>
            </tree>
        </field>
    </record>

    <!-- ── Search View ───────────────────────────────────────────────────── -->
    <record id="view_absent_deduction_log_search" model="ir.ui.view">
        <field name="name">absent.deduction.log.search</field>
        <field name="model">absent.deduction.log</field>
        <field name="arch" type="xml">
            <search string="Search Logs">
                <field name="employee_id"/>
                <field name="check_date"/>
                <filter string="Deducted" name="deducted" domain="[('status','=','deducted')]"/>
                <filter string="Skipped" name="skipped" domain="[('status','=','skipped')]"/>
                <separator/>
                <filter string="Today" name="today"
                    domain="[('check_date','=', context_today().strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Employee" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'check_date'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Action ────────────────────────────────────────────────────────── -->
    <record id="action_absent_deduction_log" model="ir.actions.act_window">
        <field name="name">Absent Deduction Logs</field>
        <field name="res_model">absent.deduction.log</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_absent_deduction_log_search"/>
    </record>

</odoo>
