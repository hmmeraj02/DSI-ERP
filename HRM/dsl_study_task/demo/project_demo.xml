<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="project_general_tasks" model="project.project">
        <field name="name">General Tasks</field>
        <field name="allow_task_dependencies" eval="False"/>
    </record>

    <record id="stage_new" model="project.task.type">
        <field name="name">New</field>
        <field name="sequence">1</field>
        <field name="project_ids" eval="[(4, ref('project_general_tasks'))]"/>
    </record>

    <record id="stage_in_progress" model="project.task.type">
        <field name="name">In-progress</field>
        <field name="sequence">2</field>
        <field name="project_ids" eval="[(4, ref('project_general_tasks'))]"/>
    </record>

    <record id="stage_done" model="project.task.type">
        <field name="name">Done</field>
        <field name="sequence">3</field>
        <field name="project_ids" eval="[(4, ref('project_general_tasks'))]"/>
    </record>

    <record id="stage_pending" model="project.task.type">
        <field name="name">Pending</field>
        <field name="sequence">4</field>
        <field name="project_ids" eval="[(4, ref('project_general_tasks'))]"/>
    </record>

</odoo>
