<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Record Rule: Prevent manual deletion of deduction logs -->
        <record id="leave_deduction_log_delete_rule" model="ir.rule">
            <field name="name">Deduction Log: No Manual Delete</field>
            <field name="model_id" ref="model_leave_deduction_log" />
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True" />
            <field name="perm_write" eval="False" />
            <field name="perm_create" eval="False" />
            <field name="perm_unlink" eval="False" />
            <field name="groups" eval="[(4, ref('hr.group_hr_manager'))]" />
        </record>
    </data>
</odoo>