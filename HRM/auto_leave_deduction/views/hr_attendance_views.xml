<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_attendance_list_inherit_deduction" model="ir.ui.view">
        <field name="name">hr.attendance.list.inherit.deduction</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.view_attendance_tree"/>
        <field name="arch" type="xml">

            <!-- worked_hours, overtime_hours → optional hide -->
            <field name="worked_hours" position="attributes">
                <attribute name="optional">hide</attribute>
            </field>
            <field name="overtime_hours" position="attributes">
                <attribute name="optional">hide</attribute>
            </field>

            <!-- Check Out এর পরে Status column যোগ -->
            <field name="check_out" position="after">

                <!-- status_type invisible — decoration এর জন্য দরকার -->
                <field name="status_type" column_invisible="1"/>

                <!--
                    Status column:
                    decoration-success  → Green  (ok)
                    decoration-danger   → Red    (late, post_noon, early_checkout, late_early, absent)
                    decoration-warning  → Yellow (leave, sat_off)
                -->
                <field name="status_label"
                       string="Status"
                       readonly="1"
                       optional="show"
                       decoration-success="status_type == 'ok'"
                       decoration-danger="status_type in ('late', 'post_noon', 'early_checkout', 'late_early', 'missed_checkout', 'absent')"
                       decoration-warning="status_type in ('leave', 'sat_off')"/>

            </field>

        </field>
    </record>

    <record id="view_attendance_form_inherit_deduction" model="ir.ui.view">
        <field name="name">hr.attendance.form.inherit.deduction</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.hr_attendance_view_form"/>
        <field name="arch" type="xml">

            <data>
                <xpath expr="//field[@name='overtime_hours']" position="after">
                    <field name="status_label"/>
                </xpath>
            </data>

        </field>
    </record>

</odoo>