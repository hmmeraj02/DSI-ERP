<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Wizard Form View ──────────────────────────────────────────────── -->
    <record id="view_attendance_summary_wizard_form" model="ir.ui.view">
        <field name="name">attendance.summary.wizard.form</field>
        <field name="model">attendance.summary.wizard</field>
        <field name="arch" type="xml">
            <form string="Attendance Summary Report">
                <group>
                    <group string="Date Range">
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group string="Filter By">
                        <field name="department_id"/>
                        <field name="employee_ids" widget="many2many_tags"
                               options="{'no_create': True}"/>
                    </group>
                </group>
                <footer>
                    <button name="action_print_report"
                            string="Print / Download PDF"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ── Wizard Action ─────────────────────────────────────────────────── -->
    <record id="action_attendance_summary_wizard" model="ir.actions.act_window">
        <field name="name">Attendance Summary Report</field>
        <field name="res_model">attendance.summary.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- ── Menu Item under Attendance ───────────────────────────────────── -->
    <menuitem
        id="menu_attendance_summary_report"
        name="Attendance Summary"
        parent="hr_attendance.menu_hr_attendance_root"
        action="action_attendance_summary_wizard"
        sequence="25"/>

</odoo>
